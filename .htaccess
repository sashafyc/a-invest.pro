Options -Indexes

# Редиректы старых страниц (301 — постоянный)
Redirect 301 /cases /blog.html
Redirect 301 /law /index.html
Redirect 301 /links /index.html
Redirect 301 /politics /index.html
Redirect 301 /sessionold /about.html
Redirect 301 /confidentially /index.html
Redirect 301 /fulfilment /index.html
Redirect 301 /page26473057.html /index.html
Redirect 301 /page26698073.html /index.html
Redirect 301 /price-list /index.html
Redirect 301 /consulting /about.html
Redirect 301 /valuation /index.html
Redirect 301 /_template.html /index.html

# Кэширование статики
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
</IfModule>
